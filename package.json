{
  "name": "anylang-dev",
  "version": "0.2.1",
  "description": "Bring-your-own-key website translation JSON generator.",
  "type": "module",
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "anylang": "bin/anylang.js"
  },
  "exports": {
    ".": "./src/runtime.js",
    "./runtime": {
      "types": "./src/runtime.d.ts",
      "default": "./src/runtime.js"
    },
    "./vite": {
      "types": "./src/vite.d.ts",
      "default": "./src/vite.js"
    },
    "./jsx-runtime": {
      "types": "./src/jsx-runtime.d.ts",
      "default": "./src/runtime.js"
    }
  },
  "scripts": {
    "test": "node --test"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "i18n",
    "translation",
    "localization",
    "gemini",
    "react",
    "tsx"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/akshaywritescode/anylang-dev.git"
  },
  "license": "MIT",
  "dependencies": {
    "@babel/generator": "^7.29.7",
    "@babel/parser": "^7.29.7",
    "@babel/traverse": "^7.29.7",
    "@babel/types": "^7.29.7"
  }
}
